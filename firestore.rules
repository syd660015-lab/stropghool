rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidParticipant(p) {
      return p.firstName is string && p.firstName.size() > 0 && p.firstName.size() < 100 &&
             p.lastName is string && p.lastName.size() > 0 && p.lastName.size() < 100 &&
             p.birthDate is string &&
             p.age is string &&
             p.testDate is string;
    }

    function isValidTestResult(tr) {
      return tr.frequency is number && tr.errors is number;
    }

    function isValidSession(data) {
      return isValidParticipant(data.participant) &&
             isValidTestResult(data.results.test1) &&
             isValidTestResult(data.results.test2) &&
             isValidTestResult(data.results.test3) &&
             isValidTestResult(data.results.test4) &&
             data.results.interferenceScore is number &&
             data.isSimulation is bool &&
             data.profileName is string &&
             (data.get('notes', '') is string) &&
             (data.get('examinerObservations', '') is string) &&
             data.createdAt == request.time;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'ashoorgool2003@gmail.com' && request.auth.token.email_verified == true);
    }

    match /sessions/{sessionId} {
      allow list: if isSignedIn(); // Requires being logged in
      allow get: if isSignedIn();
      allow create: if isValidId(sessionId) && isValidSession(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
